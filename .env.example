# LLM API Keys (at least one required — Gemini is free)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_API_KEY=your-gemini-api-key

# LLM Settings
LLM_MATCH_THRESHOLD=0.6
LLM_PROVIDER=gemini

# LinkedIn Credentials
LINKEDIN_USER=your-email@example.com
LINKEDIN_PASS=your-password

# Indeed Credentials
INDEED_USER=your-email@example.com
INDEED_PASS=your-password

# Wellfound Credentials
WELLFOUND_USER=your-email@example.com
WELLFOUND_PASS=your-password

# Google API
GM_CREDENTIALS_FILE=service_account.json
GM_TOKEN_FILE=gmail_token.json
SHEET_ID=your-google-sheet-id

# Search Configuration
SEARCH_KEYWORDS=software engineer,backend developer,python developer
SEARCH_LOCATION=remote
MAX_APPLICATIONS_PER_RUN=10

# Resume
RESUME_PATH=resume.pdf